<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="80dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="24dp">

        <!-- App Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#40FFFFFF"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_trending_up"
                android:tint="@android:color/white" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="SubZero"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Track your subscriptions effortlessly"
            android:textColor="#CCffffff"
            android:textSize="14sp" />

        <!-- Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot Password"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <!-- Instructions -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Enter the email associated with your account so that we can send you a link to reset your password."
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:lineSpacingExtra="3dp" />

                <!-- Email label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Email"
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:textStyle="bold" />

                <!-- Email input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#AAAAAA"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#E0E0E0"
                    app:boxStrokeWidth="1dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter your email"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:weightSum="2">

                    <!-- Cancel -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Cancel"
                        android:textSize="15sp"
                        android:textColor="#5B2EFA"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        android:background="@drawable/btn_outline"
                        app:cornerRadius="14dp"
                        app:strokeColor="#5B2EFA"
                        app:strokeWidth="1.5dp" />

                    <!-- Confirm -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfirm"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Confirm"
                        android:textSize="15sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        android:background="@drawable/btn_gradient"
                        app:cornerRadius="14dp" />
                </LinearLayout>

                <!-- Confirmation message (hidden until email submitted) -->
                <TextView
                    android:id="@+id/tvConfirmationMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/demo_hint_bg"
                    android:padding="14dp"
                    android:text="If an account is associated with the email you\'ve entered, you\'ll receive an email within 2-5 minutes. Check your spam folder."
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="3dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="© 2026 SubZero. All rights reserved."
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
